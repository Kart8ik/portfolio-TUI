{
  "name": "shrikarthik",
  "version": "1.0.3",
  "type": "module",
  "bin": {
    "shrikarthik": "dist/cli.js"
  },
  "files": [
    "dist",
    "src/ascii/portrait.txt",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --watch src/frontend.tsx",
    "build": "cross-env NODE_ENV=production bun build ./src/cli.ts --outdir dist --target=node --minify",
    "start": "node dist/cli.js",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "open": "^10.1.0",
    "jimp": "^1.6.0",
    "react": "^19"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "cross-env": "^7.0.3"
  }
}
